"use client";
import Link from "next/link";import {useCallback,useEffect,useState} from "react";import styles from "../saas-management/SaasManagement.module.css";
const API=(process.env.NEXT_PUBLIC_API_URL||"http://localhost:5000/api").replace(/\/$/,"");function headers():HeadersInit{const t=typeof window!=="undefined"?localStorage.getItem("token"):null;return{"Content-Type":"application/json",...(t?{Authorization:`Bearer ${t}`}:{})}async function request<T>(p:string,i?:RequestInit):Promise<T>{const r=await fetch(`${API}${p}`,{...i,credentials:"include",cache:"no-store",headers:{...headers(),...(i?.headers||{})});const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(b?.message||`Request failed: ${r.status}`);return(b?.data??b)as T}
const panel:React.CSSProperties={border:"1px solid rgba(148,163,184,.18)",background:"rgba(15,23,42,.72)",borderRadius:16,padding:16};const small:React.CSSProperties={padding:"7px 10px",borderRadius:8,border:"1px solid rgba(148,163,184,.25)",background:"#101b2f",color:"#e5eefc"};
export default function TemplateCatalogManagement():React.ReactElement{const[c,setC]=useState<any>({registry:[],stores:[]});const[busy,setBusy]=useState(false);const[error,setError]=useState("");const[msg,setMsg]=useState("");const load=useCallback(async()=>setC(await request<any>("/template-lifecycle/registry")),[]);useEffect(()=>{void load().catch(e=>setError(String(e))) },[load]);async function perform(fn:()=>Promise<unknown>,m:string){setBusy(true);setError("");try{await fn();setMsg(m);await load()}catch(e){setError(e instanceof Error?e.message:String(e))}finally{setBusy(false)}async function run(p:string,method:string){await perform(()=>request(p,{method}),"Operation completed.")}
return <main className={styles.page}><header className={styles.pageHeader}><div><p style={color:"#67e8f9"}>SUPER ADMIN / TEMPLATE REGISTRY</p><h1>Template Registry & Lifecycle · Phase 1</h1><p>Code registry, database catalog, health, activation and certification.</p></div><div className={styles.headerActions}><button style={small} disabled={busy} onClick={()=>void run("/template-lifecycle/sync","POST")}>Sync Code Templates</button><button style={small} onClick={()=>void load()}>Refresh</button><Link style={...small,textDecoration:"none"} href="/system/runtime-domain">Runtime & Domains</Link></div></header>{error?<p style={...panel,color:"#fecaca"}>{error}</p>:null}{msg?<p style={...panel,color:"#a7f3d0"}>{msg}</p>:null}<section style={...panel,marginBottom:16}><h2>Registry</h2><div className={styles.dataGrid}>{(c.registry||[]).map((item:any)=><article key={item.id} style={panel}><strong>{item.name}</strong><div>{item.slug} · {item.source_type} · {item.health}</div><p style={overflowWrap:"anywhere"}>{item.code_path||"Imported template"}</p><div style={display:"flex",gap:8,flexWrap:"wrap"}></div></article>)}</div></section><section style={panel}><h2>Store Assignments</h2><div className={styles.dataGrid}>{(c.stores||[]).map((store:any)=><article key={store.id} style={panel}><strong>{store.tenant?.name||"No tenant"} / {store.name}</strong><div>{store.domains?.find((d:any)=>d.isPrimary)?.hostname||store.domains?.[0]?.hostname||"No domain"}</div>{(store.templates||[]).map((a:any)=><div key={a.id} style={marginTop:10,paddingTop:10,borderTop:"1px solid #243147"}><b>{a.template.name}</b><div>{a.isActive?"ACTIVE":"AVAILABLE"} · {a.template.slug}</div></div>)}<div style={display:"flex",gap:8,flexWrap:"wrap",marginTop:12}></div></article>)}</div></section></main>}
