router.get("/dlr/:messageId", protect, async (req, res) => {
  try {
    const cfg = await readCredentials();
    const messageId = String(req.params.messageId);
    const url = `${cfg.dlrEndpoint}?apikey=${encodeURIComponent(cfg.apiKey)}&secretkey=${encodeURIComponent(cfg.secretKey)}&messageid=${encodeURIComponent(messageId)}`;

    const response = await fetch(url);
    const text = await response.text();

    let parsed: any = {};
    try {
      parsed = JSON.parse(text);
    } catch {
      parsed = { raw: text };
    }

    await prisma.smsLog.updateMany({
      where: { providerMessageId: messageId },
      data: { deliveryStatus: String(parsed.Text || parsed.Status || "") },
    });

    res.json({ success: true, data: parsed });
  } catch (error: any) {
    res.status(500).json({ success: false, message: error.message || "DLR check failed" });
  }
});

export default router;
