});

router.post("/otp/send", async (req, res) => {
  try {
    const phone = normalizePhone(req.body.phone);
    const purpose = String(req.body.purpose || "REGISTRATION").toUpperCase();

    if (!phone || phone.length < 10) {
      return res.status(400).json({ success: false, message: "Valid phone is required" });
    }

    const otp = makeOtp();

    await prisma.otpVerification.create({
      data: {
        phone,
        otp: otp,
        expiresAt: new Date(Date.now() + OTP_EXPIRY_MINUTES * 60 * 1000),
      },
    });

    await sendSongbirdSms(phone, `Your verification code is ${otp}. It will expire in ${OTP_EXPIRY_MINUTES} minutes.`, `OTP_${purpose}`);

    res.json({ success: true, message: "OTP sent" });
  } catch (error: any) {
    res.status(500).json({ success: false, message: error.message || "OTP send failed" });
  }
});

router.post("/otp/verify", async (req, res) => {
  try {
    const phone = normalizePhone(req.body.phone);
    const otp = String(req.body.otp || "");
    const purpose = String(req.body.purpose || "REGISTRATION").toUpperCase();

    const record = await prisma.otpVerification.findFirst({
      where: {
        phone,
        verified: false,
        expiresAt: { gt: new Date() },
      },
      orderBy: { createdAt: "desc" },
    });

    if (!record) {
      return res.status(400).json({ success: false, message: "OTP expired or not found" });
    }


    if (record.otp !== otp) {
      return res.status(400).json({ success: false, message: "Invalid OTP" });
    }

    await prisma.otpVerification.update({
      where: { id: record.id },
      data: { verified: true },
    });

    let user = await prisma.user.findFirst({
      where: { phone },
    });

    if (!user) {
      user = await prisma.user.create({
        data: {
          name: `Customer ${phone.slice(-4)}`,
          email: `${phone}@phone.saqso.local`,
          phone,
          password: hashValue(`PHONE_AUTH_${phone}`),
          role: "CUSTOMER",
        } as any,
      });
    }

