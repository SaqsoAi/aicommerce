generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                  @id @default(cuid())
  name                  String
  email                 String                  @unique
  password              String
  createdAt             DateTime                @default(now())
  avatar                String?
  phone                 String?                 @unique
  updatedAt             DateTime                @updatedAt
  role                  UserRole                @default(CUSTOMER)
  permissions           Json?
  emailVerified         Boolean                 @default(false)
  provider              String?                 @default("LOCAL")
  providerId            String?
  addressLine1          String?
  addressLine2          String?
  alternatePhone        String?
  bio                   String?
  city                  String?
  country               String?
  dateOfBirth           DateTime?
  emailOptIn            Boolean                 @default(true)
  facebookUrl           String?
  firstName             String?
  gender                String?
  instagramUrl          String?
  lastName              String?
  linkedinUrl           String?
  marketingOptIn        Boolean                 @default(true)
  postalCode            String?
  preferredCurrency     String?                 @default("BDT")
  preferredLanguage     String?                 @default("en")
  smsOptIn              Boolean                 @default(false)
  state                 String?
  themeMode             String?                 @default("SYSTEM")
  tiktokUrl             String?
  twitterUrl            String?
  websiteUrl            String?
  youtubeUrl            String?
  rewardWalletId        String?
  tenantId              String?
  storeId               String?
  cartItems             Cart[]
  customerActivities    CustomerActivity[]
  customerPreferences   CustomerPreference[]
  customerStyleProfile  CustomerStyleProfile?
  orders                Order[]
  recommendationHistory RecommendationHistory[]
  reviews               Review[]
  savedLooks            SavedLook[]
  socialAccounts        SocialAccount[]
  rewardWallet          RewardWallet?           @relation(fields: [rewardWalletId], references: [id])
  store                 Store?                  @relation(fields: [storeId], references: [id])
  tenant                Tenant?                 @relation(fields: [tenantId], references: [id])
  userTenantRoles       UserTenantRole[]
  virtualTryOnJobs      VirtualTryOnJob[]
  wishlist              Wishlist[]

  @@index([tenantId])
  @@index([storeId])
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  image         String?
  createdAt     DateTime      @default(now())
  storeId       String?
  tenantId      String?
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  categoryId String
  createdAt  DateTime  @default(now())
  storeId    String?
  tenantId   String?
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id])
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  logo     String?
  storeId  String?
  tenantId String?
  products Product[]
}

model Product {
  id                   String              @id @default(cuid())
  name                 String
  description          String
  price                Float
  createdAt            DateTime            @default(now())
  aiGenerated          Boolean             @default(false)
  barcode              String?
  brandId              String?
  categoryId           String
  discountPrice        Float?
  featured             Boolean             @default(false)
  shortDescription     String?
  sku                  String              @unique
  slug                 String              @unique
  subcategoryId        String?
  thumbnail            String?
  trending             Boolean             @default(false)
  updatedAt            DateTime            @updatedAt
  styleNo              String?
  videoUrl             String?
  gallery              Json?
  externalId           String?
  externalSystem       String?
  lastSyncedAt         DateTime?
  masterDataSource     String?             @default("MANUAL")
  syncEnabled          Boolean             @default(false)
  seoDescription       String?
  seoKeywords          String?
  seoTitle             String?
  status               String              @default("DRAFT")
  visibility           String              @default("PUBLIC")
  attributes           Json?
  specifications       Json?
  condition            String              @default("NEW")
  groupName            String?
  approvalNote         String?
  approvalStatus       String              @default("APPROVED")
  approvedAt           DateTime?
  approvedBy           String?
  publishAt            DateTime?
  submittedForReviewAt DateTime?
  unpublishAt          DateTime?
  storeId              String?
  tenantId             String?
  cartItems            Cart[]
  inventoryMovements   InventoryMovement[]
  lookbookLinks        LookbookProduct[]
  orderItems           OrderItem[]
  brand                Brand?              @relation(fields: [brandId], references: [id])
  category             Category            @relation(fields: [categoryId], references: [id])
  subcategory          Subcategory?        @relation(fields: [subcategoryId], references: [id])
  productAiMeta        ProductAiMeta?
  approvals            ProductApproval[]
  images               ProductImage[]
  productSeo           ProductSeo?
  variants             ProductVariant[]
  reviews              Review[]
  virtualTryOnJobs     VirtualTryOnJob[]
  wishlist             Wishlist[]
}

model ProductVariant {
  id                String           @id @default(cuid())
  productId         String
  color             String
  size              String
  stock             Int              @default(0)
  price             Float?
  barcode           String?
  createdAt         DateTime         @default(now())
  sku               String           @unique
  active            Boolean          @default(true)
  updatedAt         DateTime         @updatedAt
  availableStock    Int              @default(0)
  lowStockThreshold Int              @default(5)
  reservedStock     Int              @default(0)
  supplierSku       String?
  warehouseLocation String?
  costPrice         Float?
  fabric            String?
  occasion          String?
  salesPrice        Float?
  styleNo           String?
  systemBarcode     String?
  storeId           String?
  tenantId          String?
  product           Product          @relation(fields: [productId], references: [id])
  supplierReturns   SupplierReturn[]
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  url         String
  createdAt   DateTime @default(now())
  isThumbnail Boolean  @default(false)
  sortOrder   Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductApproval {
  id         String   @id @default(cuid())
  productId  String
  action     String
  fromStatus String?
  toStatus   String
  note       String?
  actorId    String?
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([action])
  @@index([toStatus])
  @@index([createdAt])
}

model Review {
  id               String   @id @default(cuid())
  rating           Int
  comment          String?
  userId           String
  productId        String
  createdAt        DateTime @default(now())
  bodyType         String?
  fitRating        String?
  heightCm         Float?
  isApproved       Boolean  @default(false)
  isFeatured       Boolean  @default(false)
  reviewImages     Json?
  sizeOrdered      String?
  verifiedPurchase Boolean  @default(false)
  weightKg         Float?
  storeId          String?
  tenantId         String?
  product          Product  @relation(fields: [productId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  storeId   String?
  tenantId  String?
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Cart {
  id        String  @id @default(cuid())
  quantity  Int
  userId    String
  productId String
  storeId   String?
  tenantId  String?
  product   Product @relation(fields: [productId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Float
  active     Boolean  @default(true)
  expiryDate DateTime
  storeId    String?
  tenantId   String?
}

model Order {
  id              String          @id @default(cuid())
  totalAmount     Float
  status          OrderStatus     @default(PENDING)
  paymentStatus   PaymentStatus   @default(PENDING)
  transactionId   String?
  userId          String
  createdAt       DateTime        @default(now())
  courierName     String?
  customerAddress String
  customerName    String
  customerPhone   String
  deliveryCharge  Float           @default(0)
  discountAmount  Float           @default(0)
  finalAmount     Float
  orderNumber     String          @unique
  paymentMethod   String
  trackingCode    String?
  shipmentStatus  String?         @default("PENDING")
  invoiceNumber   String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  storeId         String?
  tenantId        String?
  user            User            @relation(fields: [userId], references: [id])
  items           OrderItem[]
  notes           OrderNote[]
  timelines       OrderTimeline[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  productId String
  storeId   String?
  tenantId  String?
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model OrderTimeline {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  message   String
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String
  note      String
  createdBy String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model FraudLog {
  id        String   @id @default(cuid())
  ipAddress String
  riskScore Float
  reason    String
  createdAt DateTime @default(now())
}

model AILog {
  id        String   @id @default(cuid())
  feature   String
  prompt    String
  response  String
  createdAt DateTime @default(now())
}

model Supplier {
  id               String            @id @default(cuid())
  name             String
  email            String?
  phone            String?
  createdAt        DateTime          @default(now())
  active           Boolean           @default(true)
  address          String?
  companyName      String?
  contactPerson    String?
  notes            String?
  updatedAt        DateTime          @updatedAt
  website          String?
  supplierCode     String?           @unique
  purchaseOrders   PurchaseOrder[]
  supplierLedgers  SupplierLedger[]
  supplierPayments SupplierPayment[]
  supplierReturns  SupplierReturn[]
}

model Campaign {
  id            String   @id @default(cuid())
  title         String
  type          String
  active        Boolean  @default(true)
  startDate     DateTime
  endDate       DateTime
  discountValue Float?
  storeId       String?
  tenantId      String?
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  method        String
  transactionId String?
  status        String
  amount        Float
  createdAt     DateTime @default(now())
}

model Shipment {
  id           String   @id @default(cuid())
  orderId      String
  courier      String
  trackingCode String?
  status       String
  createdAt    DateTime @default(now())
}

model StoreTemplate {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  isActive   Boolean  @default(false)
  storeId    String
  templateId String
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([storeId, templateId])
  @@index([storeId])
  @@index([templateId])
}

model StoreConfig {
  id             String   @id @default(cuid())
  storeName      String
  logo           String?
  theme          String
  activeTemplate String
  primaryColor   String
  createdAt      DateTime @default(now())
}

model InstalledTemplate {
  id        String   @id @default(cuid())
  name      String
  slug      String
  version   String
  createdAt DateTime @default(now())
  status    String   @default("active")
}

model TemplateSettings {
  id        String   @id @default(cuid())
  template  String   @unique
  config    Json
  updatedAt DateTime @updatedAt
}

model Hero {
  id            String      @id @default(cuid())
  title         String
  subtitle      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  active        Boolean     @default(true)
  buttonLink    String?
  buttonText    String?
  endDate       DateTime?
  image         String?
  secondaryLink String?
  secondaryText String?
  type          String
  video         String?
  startDate     DateTime?
  slides        HeroSlide[]
}

model HeroSlide {
  id                  String   @id @default(cuid())
  heroId              String
  title               String
  subtitle            String?
  image               String
  buttonText          String?
  buttonLink          String?
  order               Int      @default(0)
  createdAt           DateTime @default(now())
  buttonPosition      String?  @default("center")
  primaryButtonLink   String?
  primaryButtonText   String?
  secondaryButtonLink String?
  secondaryButtonText String?
  hero                Hero     @relation(fields: [heroId], references: [id], onDelete: Cascade)
}

model Template {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  createdAt   DateTime        @default(now())
  description String?
  isActive    Boolean         @default(true)
  previewUrl  String?
  updatedAt   DateTime        @updatedAt
  stores      StoreTemplate[]
}

model Media {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  fileName  String?
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  folder    String?  @default("general")
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analytics {
  id         String   @id @default(cuid())
  heroViews  Int      @default(0)
  heroClicks Int      @default(0)
  ctr        Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  status            String             @default("ACTIVE")
  storefrontEnabled Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  homepageSections  HomepageSection[]
  stores            Store[]
  domains           StorefrontDomain[]
  users             User[]
  userTenantRoles   UserTenantRole[]

  @@index([status, storefrontEnabled])
}

model StorefrontDomain {
  id                String    @id @default(cuid())
  hostname          String    @unique
  status            String    @default("ACTIVE")
  isPrimary         Boolean   @default(false)
  tenantId          String
  storeId           String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  provider          String?   @default("MANUAL")
  verificationToken String?   @unique
  dnsStatus         String    @default("PENDING")
  sslStatus         String    @default("PENDING")
  lastVerifiedAt    DateTime?
  store             Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, storeId])
  @@index([status])
}

model Store {
  id                String             @id @default(cuid())
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenantId          String?
  status            String             @default("ACTIVE")
  storefrontEnabled Boolean            @default(true)
  primaryDomain     String?
  homepageSections  HomepageSection[]
  tenant            Tenant?            @relation(fields: [tenantId], references: [id])
  templates         StoreTemplate[]
  domains           StorefrontDomain[]
  users             User[]
  userTenantRoles   UserTenantRole[]

  @@index([tenantId])
  @@index([status, storefrontEnabled])
}

model Integration {
  id        String   @id @default(cuid())
  name      String
  provider  String
  apiUrl    String
  apiKey    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCodeSettings {
  id             String   @id @default(cuid())
  barcodePrefix  String   @default("899001")
  stylePrefix    String   @default("PRD")
  barcodeCounter Int      @default(1)
  styleCounter   Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String
  orderNumber String              @unique
  status      String              @default("PENDING")
  totalAmount Float               @default(0)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  grns        GoodsReceiveNote[]
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  costPrice       Float
  createdAt       DateTime      @default(now())
  barcode         String?
  color           String?
  receivedQty     Int           @default(0)
  salesPrice      Float?
  size            String?
  sku             String?
  styleNo         String?
  updatedAt       DateTime      @default(now()) @updatedAt
  variantId       String?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([variantId])
}

model InventoryTransaction {
  id              String   @id @default(cuid())
  variantId       String
  transactionType String
  quantity        Int
  previousStock   Int
  newStock        Int
  referenceId     String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([variantId])
  @@index([transactionType])
  @@index([referenceId])
}

model GoodsReceiveNote {
  id              String                 @id @default(cuid())
  purchaseOrderId String
  grnNumber       String                 @unique
  status          String                 @default("COMPLETED")
  totalQty        Int                    @default(0)
  totalAmount     Float                  @default(0)
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  purchaseOrder   PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items           GoodsReceiveNoteItem[]

  @@index([purchaseOrderId])
}

model GoodsReceiveNoteItem {
  id        String           @id @default(cuid())
  grnId     String
  productId String
  variantId String
  quantity  Int
  costPrice Float
  salePrice Float?
  createdAt DateTime         @default(now())
  grn       GoodsReceiveNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@index([grnId])
  @@index([variantId])
}

model SupplierLedger {
  id          String   @id @default(cuid())
  supplierId  String
  type        String
  amount      Float
  referenceId String?
  notes       String?
  createdAt   DateTime @default(now())
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([type])
}

model SupplierPayment {
  id          String   @id @default(cuid())
  supplierId  String
  amount      Float
  method      String
  referenceNo String?
  notes       String?
  createdAt   DateTime @default(now())
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model SupplierReturn {
  id         String         @id @default(cuid())
  supplierId String
  variantId  String
  quantity   Int
  reason     String?
  status     String         @default("COMPLETED")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  supplier   Supplier       @relation(fields: [supplierId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  userId      String?
  createdAt   DateTime @default(now())
  description String?
  ipAddress   String?
  module      String
}

model HomepageSection {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  type      String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String?
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, storeId, enabled, sortOrder])
  @@index([storeId, slug])
}

model StoreSetting {
  id             String   @id @default(cuid())
  singletonKey   String   @unique @default("main")
  storeName      String   @default("AI Commerce")
  storeTagline   String?
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#111827")
  secondaryColor String   @default("#6D28D9")
  phone          String?
  email          String?
  address        String?
  aboutTitle     String?
  aboutText      String?
  footerText     String?
  facebookUrl    String?
  instagramUrl   String?
  tiktokUrl      String?
  youtubeUrl     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  themeMode      String   @default("SYSTEM")
  headerStyle    String   @default("GLASS")
  heroStyle      String   @default("PREMIUM")
  buttonStyle    String   @default("LUXURY")
  footerStyle    String   @default("PREMIUM")
  activeTemplate String   @default("saqsobuild")
}

model SocialAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  providerId String
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model CustomerProfileField {
  id          String   @id @default(cuid())
  name        String
  label       String
  type        String
  placeholder String?
  required    Boolean  @default(false)
  visible     Boolean  @default(true)
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isSystem    Boolean  @default(false)
}

model CustomerProfileValue {
  id        String   @id @default(cuid())
  userId    String
  fieldId   String
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MembershipTier {
  id              String            @id @default(cuid())
  name            String
  minOrderAmount  Float
  discountPercent Float             @default(0)
  active          Boolean           @default(true)
  sortOrder       Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  supplierCode    String?           @unique
  cards           MembershipCard[]
  claims          MembershipClaim[]
}

model MembershipCard {
  id             String         @id @default(cuid())
  cardNumber     String         @unique
  pinCode        String
  status         String         @default("AVAILABLE")
  tierId         String
  assignedUserId String?
  activatedAt    DateTime?
  expiresAt      DateTime?
  sentToWhatsapp String?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  activationNote String?
  cardImageUrl   String?
  qrCodeUrl      String?
  tier           MembershipTier @relation(fields: [tierId], references: [id])
}

model MembershipClaim {
  id               String         @id @default(cuid())
  userId           String
  tierId           String
  orderId          String?
  invoiceAmount    Float
  status           String         @default("PENDING")
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  adminInstruction String?
  customerName     String?
  customerPhone    String?
  customerWhatsapp String?
  profileSnapshot  Json?
  tier             MembershipTier @relation(fields: [tierId], references: [id])
}

model RewardPointRule {
  id          String   @id @default(cuid())
  title       String
  ruleType    String
  spendAmount Float?
  quantity    Int?
  points      Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RewardRedemptionRule {
  id              String   @id @default(cuid())
  title           String
  requiredPoints  Int
  rewardType      String
  discountAmount  Float?
  discountPercent Float?
  freeDelivery    Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
