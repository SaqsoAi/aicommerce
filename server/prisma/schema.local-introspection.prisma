  trusted         Boolean                  @default(false)
  allowedChannels PluginReleaseChannel[]
  metadata        Json?
  createdBy       String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  downloads       PluginDownloadHistory[]
  entries         PluginMarketplaceEntry[]
}

model PluginMarketplaceEntry {
  id                     String                     @id @default(cuid())
  pluginId               String?
  pluginVersionId        String?
  vendorId               String
  signingKeyId           String?
  repositoryId           String
  pluginKey              String
  name                   String
  version                String
  channel                PluginReleaseChannel
  description            String?
  minimumPlatformVersion String
  maximumPlatformVersion String
  packageSha256          String
  packageSizeBytes       Int
  signatureAlgorithm     String?
  signatureBase64        String?
  signedDigest           String?
  trustDecision          PluginPackageTrustDecision @default(UNTRUSTED)
  trustReasons           Json?
  manifest               Json
  changelog              String?
  packageLocation        String?
  publishedAt            DateTime?
  revokedAt              DateTime?
  revokedReason          String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  downloads              PluginDownloadHistory[]
  plugin                 Plugin?                    @relation(fields: [pluginId], references: [id])
  pluginVersion          PluginVersion?             @relation(fields: [pluginVersionId], references: [id])
  repository             PluginRepository           @relation(fields: [repositoryId], references: [id])
  signingKey             PluginSigningKey?          @relation(fields: [signingKeyId], references: [id])
  vendor                 PluginVendor               @relation(fields: [vendorId], references: [id])

  @@unique([repositoryId, pluginKey, version, channel])
  @@index([pluginKey, channel, publishedAt])
  @@index([trustDecision, publishedAt])
}

model PluginDownloadHistory {
  id                 String                     @id @default(cuid())
  marketplaceEntryId String
  repositoryId       String
  actorId            String
  purpose            String
  outcome            String
  packageSha256      String
  trustDecision      PluginPackageTrustDecision
  metadata           Json?
  createdAt          DateTime                   @default(now())
  marketplaceEntry   PluginMarketplaceEntry     @relation(fields: [marketplaceEntryId], references: [id], onDelete: Cascade)
  repository         PluginRepository           @relation(fields: [repositoryId], references: [id])

  @@index([actorId, createdAt])
  @@index([marketplaceEntryId, createdAt])
}

