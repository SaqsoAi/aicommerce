generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  customerActivities    CustomerActivity[]
  customerStyleProfile  CustomerStyleProfile?
  customerPreferences   CustomerPreference[]
  recommendationHistory RecommendationHistory[]
  savedLooks            SavedLook[]
  virtualTryOnJobs      VirtualTryOnJob[]
  id                    String                  @id @default(cuid())
  name                  String
  email                 String                  @unique
  password              String
  createdAt             DateTime                @default(now())
  avatar                String?
  firstName             String?
  lastName              String?
  dateOfBirth           DateTime?
  gender                String?
  bio                   String?
  alternatePhone        String?
  country               String?
  state                 String?
  city                  String?
  postalCode            String?
  addressLine1          String?
  addressLine2          String?
  facebookUrl           String?
  instagramUrl          String?
  twitterUrl            String?
  linkedinUrl           String?
  youtubeUrl            String?
  tiktokUrl             String?
  websiteUrl            String?
  rewardWallet          RewardWallet?           @relation(fields: [rewardWalletId], references: [id])
  socialAccounts        SocialAccount[]

  preferredLanguage String? @default("en")
  preferredCurrency String? @default("BDT")

  themeMode String? @default("SYSTEM")

  marketingOptIn Boolean    @default(true)
  smsOptIn       Boolean    @default(false)
  emailOptIn     Boolean    @default(true)
  phone          String?    @unique
  provider       String?    @default("LOCAL")
  providerId     String?
  emailVerified  Boolean    @default(false)
  updatedAt      DateTime   @updatedAt
  role           UserRole   @default(CUSTOMER)
  permissions    Json?
  cartItems      Cart[]
  orders         Order[]
  reviews        Review[]
  wishlist       Wishlist[]
  rewardWalletId String?

  tenantId        String?
  storeId         String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  store           Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  userTenantRoles UserTenantRole[]

  @@index([tenantId])
  @@index([storeId])
}

model Category {
  tenantId      String?
  storeId       String?
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  image         String?
  createdAt     DateTime      @default(now())
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  tenantId   String?
  storeId    String?
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  categoryId String
  createdAt  DateTime  @default(now())
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id])
}

model Brand {
  tenantId String?
  storeId  String?
  id       String    @id @default(cuid())
  name     String    @unique
  logo     String?
  products Product[]
}

model Product {
  tenantId             String?
  storeId              String?
  lookbookLinks        LookbookProduct[]
  virtualTryOnJobs     VirtualTryOnJob[]
  id                   String              @id @default(cuid())
  name                 String
  groupName            String?
  description          String
  price                Float
  createdAt            DateTime            @default(now())
  aiGenerated          Boolean             @default(false)
  barcode              String?
  brandId              String?
  categoryId           String
  discountPrice        Float?
  featured             Boolean             @default(false)
  shortDescription     String?
  sku                  String              @unique
  slug                 String              @unique
  subcategoryId        String?
  thumbnail            String?
  trending             Boolean             @default(false)
  updatedAt            DateTime            @updatedAt
  styleNo              String?
  videoUrl             String?
  gallery              Json?
  externalId           String?
  externalSystem       String?
  lastSyncedAt         DateTime?
  masterDataSource     String?             @default("MANUAL")
  syncEnabled          Boolean             @default(false)
  seoDescription       String?
  seoKeywords          String?
  seoTitle             String?
  status               String              @default("DRAFT")
  visibility           String              @default("PUBLIC")
  approvalStatus       String              @default("APPROVED")
  approvalNote         String?
  submittedForReviewAt DateTime?
  approvedBy           String?
  approvedAt           DateTime?
  publishAt            DateTime?
  unpublishAt          DateTime?
  attributes           Json?
  specifications       Json?
  condition            String              @default("NEW")
  approvals            ProductApproval[]
  cartItems            Cart[]
  orderItems           OrderItem[]
  brand                Brand?              @relation(fields: [brandId], references: [id])
  category             Category            @relation(fields: [categoryId], references: [id])
  subcategory          Subcategory?        @relation(fields: [subcategoryId], references: [id])
  images               ProductImage[]
  variants             ProductVariant[]
  reviews              Review[]
  wishlist             Wishlist[]
  productSeo           ProductSeo?
  productAiMeta        ProductAiMeta?
  inventoryMovements   InventoryMovement[]
}

model ProductVariant {
  tenantId          String?
  storeId           String?
  id                String           @id @default(cuid())
  productId         String
  color             String
  size              String
  stock             Int              @default(0)
  price             Float?
  barcode           String?
  styleNo           String?
  systemBarcode     String?
  fabric            String?
  occasion          String?
  costPrice         Float?
  salesPrice        Float?
  createdAt         DateTime         @default(now())
  sku               String           @unique
  active            Boolean          @default(true)
  updatedAt         DateTime         @updatedAt
  availableStock    Int              @default(0)
  lowStockThreshold Int              @default(5)
  reservedStock     Int              @default(0)
  supplierSku       String?
  warehouseLocation String?
  product           Product          @relation(fields: [productId], references: [id])
  supplierReturns   SupplierReturn[]
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  url         String
  createdAt   DateTime @default(now())
  isThumbnail Boolean  @default(false)
  sortOrder   Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductApproval {
  id         String   @id @default(cuid())
  productId  String
  action     String
  fromStatus String?
  toStatus   String
  note       String?
  actorId    String?
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([action])
  @@index([toStatus])
  @@index([createdAt])
}

model Review {
  tenantId         String?
  storeId          String?
  fitRating        String?
  bodyType         String?
  heightCm         Float?
  weightKg         Float?
  sizeOrdered      String?
  reviewImages     Json?
  verifiedPurchase Boolean  @default(false)
  isApproved       Boolean  @default(false)
  isFeatured       Boolean  @default(false)
  id               String   @id @default(cuid())
  rating           Int
  comment          String?
  userId           String
  productId        String
  createdAt        DateTime @default(now())
  product          Product  @relation(fields: [productId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
}

model Wishlist {
  tenantId  String?
  storeId   String?
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Cart {
  tenantId  String?
  storeId   String?
  id        String  @id @default(cuid())
  quantity  Int
  userId    String
  productId String
  product   Product @relation(fields: [productId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
}

model Coupon {
  tenantId   String?
  storeId    String?
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Float
  active     Boolean  @default(true)
  expiryDate DateTime
}

model Order {
  tenantId        String?
  storeId         String?
  id              String          @id @default(cuid())
  totalAmount     Float
  status          OrderStatus     @default(PENDING)
  paymentStatus   PaymentStatus   @default(PENDING)
  transactionId   String?
  userId          String
  createdAt       DateTime        @default(now())
  courierName     String?
  customerAddress String
  customerName    String
  customerPhone   String
  deliveryCharge  Float           @default(0)
  discountAmount  Float           @default(0)
  finalAmount     Float
  orderNumber     String          @unique
  paymentMethod   String
  user            User            @relation(fields: [userId], references: [id])
  items           OrderItem[]
  timelines       OrderTimeline[]
  notes           OrderNote[]

  trackingCode   String?
  shipmentStatus String? @default("PENDING")
  invoiceNumber  String?

  shippedAt   DateTime?
  deliveredAt DateTime?
}

model OrderItem {
  tenantId  String?
  storeId   String?
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model OrderTimeline {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  message   String
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String
  note      String
  createdBy String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model FraudLog {
  id        String   @id @default(cuid())
  ipAddress String
  riskScore Float
  reason    String
  createdAt DateTime @default(now())
}

model AILog {
  id        String   @id @default(cuid())
  feature   String
  prompt    String
  response  String
  createdAt DateTime @default(now())
}

model Supplier {
  id               String            @id @default(cuid())
  name             String
  supplierCode     String?           @unique
  email            String?
  phone            String?
  createdAt        DateTime          @default(now())
  active           Boolean           @default(true)
  address          String?
  companyName      String?
  contactPerson    String?
  notes            String?
  updatedAt        DateTime          @updatedAt
  website          String?
  purchaseOrders   PurchaseOrder[]
  supplierReturns  SupplierReturn[]
  supplierLedgers  SupplierLedger[]
  supplierPayments SupplierPayment[]
}

model Campaign {
  tenantId      String?
  storeId       String?
  id            String   @id @default(cuid())
  title         String
  type          String
  active        Boolean  @default(true)
  startDate     DateTime
  endDate       DateTime
  discountValue Float?
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  method        String
  transactionId String?
  status        String
  amount        Float
  createdAt     DateTime @default(now())
}

model Shipment {
  id           String   @id @default(cuid())
  orderId      String
  courier      String
  trackingCode String?
  status       String
  createdAt    DateTime @default(now())
}

model StoreTemplate {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  isActive   Boolean  @default(false)
  storeId    String
  templateId String
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([storeId, templateId])
  @@index([storeId])
  @@index([templateId])
}

model StoreConfig {
  id             String   @id @default(cuid())
  storeName      String
  logo           String?
  theme          String
  activeTemplate String
  primaryColor   String
  createdAt      DateTime @default(now())
}

model InstalledTemplate {
  id        String   @id @default(cuid())
  name      String
  slug      String
  version   String
  createdAt DateTime @default(now())
  status    String   @default("active")
}

model TemplateSettings {
  id        String   @id @default(cuid())
  template  String   @unique
  config    Json
  updatedAt DateTime @updatedAt
}

model Hero {
  id            String      @id @default(cuid())
  title         String
  subtitle      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  active        Boolean     @default(true)
  buttonLink    String?
  buttonText    String?
  endDate       DateTime?
  image         String?
  secondaryLink String?
  secondaryText String?
  type          String
  video         String?
  startDate     DateTime?
  slides        HeroSlide[]
}

model HeroSlide {
  id                  String   @id @default(cuid())
  heroId              String
  title               String
  subtitle            String?
  image               String
  buttonText          String?
  buttonLink          String?
  order               Int      @default(0)
  createdAt           DateTime @default(now())
  buttonPosition      String?  @default("center")
  primaryButtonLink   String?
  primaryButtonText   String?
  secondaryButtonLink String?
  secondaryButtonText String?
  hero                Hero     @relation(fields: [heroId], references: [id], onDelete: Cascade)
}

model Template {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  createdAt   DateTime        @default(now())
  description String?
  isActive    Boolean         @default(true)
  previewUrl  String?
  updatedAt   DateTime        @updatedAt
  stores      StoreTemplate[]
}

model Media {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  fileName  String?
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  folder    String?  @default("general")
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analytics {
  id         String   @id @default(cuid())
  heroViews  Int      @default(0)
  heroClicks Int      @default(0)
  ctr        Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  status            String             @default("ACTIVE")
  storefrontEnabled Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  stores            Store[]
  domains           StorefrontDomain[]
  homepageSections  HomepageSection[]

  users           User[]
  userTenantRoles UserTenantRole[]

  @@index([status, storefrontEnabled])
}

model StorefrontDomain {
  id                String    @id @default(cuid())
  hostname          String    @unique
  status            String    @default("ACTIVE")
  isPrimary         Boolean   @default(false)
  provider          String?   @default("MANUAL")
  verificationToken String?   @unique
  dnsStatus         String    @default("PENDING")
  sslStatus         String    @default("PENDING")
  lastVerifiedAt    DateTime?
  tenantId          String
  storeId           String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId, storeId])
  @@index([status])
}

model Store {
  id                String             @id @default(cuid())
  name              String
  tenantId          String?
  status            String             @default("ACTIVE")
  storefrontEnabled Boolean            @default(true)
  primaryDomain     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  templates         StoreTemplate[]
  domains           StorefrontDomain[]
  homepageSections  HomepageSection[]

  users           User[]
  userTenantRoles UserTenantRole[]

  @@index([tenantId])
  @@index([status, storefrontEnabled])
}

model Integration {
  id        String   @id @default(cuid())
  name      String
  provider  String
  apiUrl    String
  apiKey    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCodeSettings {
  id             String   @id @default(cuid())
  barcodePrefix  String   @default("899001")
  stylePrefix    String   @default("PRD")
  barcodeCounter Int      @default(1)
  styleCounter   Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String
  orderNumber String              @unique
  status      String              @default("PENDING")
  totalAmount Float               @default(0)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
  grns        GoodsReceiveNote[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  variantId       String?
  sku             String?
  barcode         String?
  styleNo         String?
  color           String?
  size            String?
  quantity        Int
  receivedQty     Int           @default(0)
  costPrice       Float
  salesPrice      Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([variantId])
}

model InventoryTransaction {
  id              String   @id @default(cuid())
  variantId       String
  transactionType String
  quantity        Int
  previousStock   Int
  newStock        Int
  referenceId     String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([variantId])
  @@index([transactionType])
  @@index([referenceId])
}

model GoodsReceiveNote {
  id              String                 @id @default(cuid())
  purchaseOrderId String
  grnNumber       String                 @unique
  status          String                 @default("COMPLETED")
  totalQty        Int                    @default(0)
  totalAmount     Float                  @default(0)
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  purchaseOrder   PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items           GoodsReceiveNoteItem[]

  @@index([purchaseOrderId])
}

model GoodsReceiveNoteItem {
  id        String           @id @default(cuid())
  grnId     String
  productId String
  variantId String
  quantity  Int
  costPrice Float
  salePrice Float?
  createdAt DateTime         @default(now())
  grn       GoodsReceiveNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@index([grnId])
  @@index([variantId])
}

model SupplierLedger {
  id          String   @id @default(cuid())
  supplierId  String
  type        String
  amount      Float
  referenceId String?
  notes       String?
  createdAt   DateTime @default(now())
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([type])
}

model SupplierPayment {
  id          String   @id @default(cuid())
  supplierId  String
  amount      Float
  method      String
  referenceNo String?
  notes       String?
  createdAt   DateTime @default(now())
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model SupplierReturn {
  id         String         @id @default(cuid())
  supplierId String
  variantId  String
  quantity   Int
  reason     String?
  status     String         @default("COMPLETED")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  supplier   Supplier       @relation(fields: [supplierId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(cuid())

  userId String?

  action String

  module String

  description String?

  ipAddress String?

  createdAt DateTime @default(now())
}

model HomepageSection {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  type      String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  data      Json?
  tenantId  String?
  storeId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  store  Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([tenantId, storeId, enabled, sortOrder])
  @@index([storeId, slug])
}

model StoreSetting {
  id             String  @id @default(cuid())
  singletonKey   String  @unique @default("main")
  storeName      String  @default("AI Commerce")
  storeTagline   String?
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String  @default("#111827")
  secondaryColor String  @default("#6D28D9")
  phone          String?
  email          String?
  address        String?
  aboutTitle     String?
  aboutText      String?
  footerText     String?
  facebookUrl    String?
  instagramUrl   String?
  tiktokUrl      String?
  youtubeUrl     String?

  themeMode      String @default("SYSTEM")
  headerStyle    String @default("GLASS")
  heroStyle      String @default("PREMIUM")
  buttonStyle    String @default("LUXURY")
  footerStyle    String @default("PREMIUM")
  activeTemplate String @default("saqsobuild")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialAccount {
  id String @id @default(cuid())

  userId String

  provider String

  providerId String

  verified Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpVerification {
  id String @id @default(cuid())

  phone String

  otp String

  verified Boolean @default(false)

  expiresAt DateTime

  createdAt DateTime @default(now())
}

model CustomerProfileField {
  id String @id @default(cuid())

  name String

  label String

  type String

  placeholder String?

  required Boolean @default(false)

  visible Boolean @default(true)

  enabled Boolean @default(true)

  isSystem Boolean @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model CustomerProfileValue {
  id String @id @default(cuid())

  userId String

  fieldId String

  value String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model MembershipTier {
  id              String   @id @default(cuid())
  name            String
  supplierCode    String?  @unique
  minOrderAmount  Float
  discountPercent Float    @default(0)
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cards  MembershipCard[]
  claims MembershipClaim[]
}

model MembershipCard {
  id             String    @id @default(cuid())
  cardNumber     String    @unique
  qrCodeUrl      String?
  cardImageUrl   String?
  activationNote String?
  pinCode        String
  status         String    @default("AVAILABLE")
  tierId         String
  assignedUserId String?
  activatedAt    DateTime?
  expiresAt      DateTime?
  sentToWhatsapp String?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tier MembershipTier @relation(fields: [tierId], references: [id])
}

model MembershipClaim {
  id               String   @id @default(cuid())
  userId           String
  tierId           String
  orderId          String?
  invoiceAmount    Float
  status           String   @default("PENDING")
  note             String?
  customerName     String?
  customerPhone    String?
  customerWhatsapp String?
  profileSnapshot  Json?
  adminInstruction String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tier MembershipTier @relation(fields: [tierId], references: [id])
}

model RewardPointRule {
  id          String   @id @default(cuid())
  title       String
  ruleType    String
  spendAmount Float?
  quantity    Int?
  points      Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RewardRedemptionRule {
  id              String   @id @default(cuid())
  title           String
  requiredPoints  Int
  rewardType      String
  discountAmount  Float?
  discountPercent Float?
  freeDelivery    Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RewardWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
