model TemplateRegistryEntry {
  id             String   @id
  templateId     String   @map("template_id")
  slug           String   @unique(map: "template_registry_entries_slug_key")
  registryKey    String   @map("registry_key")
  name           String
  sourceType     String   @default("IMPORTED") @map("source_type")
  version        String   @default("1.0.0")
  vendor         String?
  engine         String   @default("NEXT_APP_ROUTER")
  codePath       String?  @map("code_path")
  previewUrl     String?  @map("preview_url")
  description    String?
  manifest       Json     @default("{}")
  health         String   @default("DISCOVERED")
  status         String   @default("REGISTERED")
  lastSyncedAt   DateTime? @db.Timestamptz(6) @map("last_synced_at")
  lastHealthAt   DateTime? @db.Timestamptz(6) @map("last_health_at")
  createdAt      DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@index([templateId], map: "idx_template_registry_template_id")
  @@index([registryKey], map: "idx_template_registry_registry_key")
  @@index([status], map: "idx_template_registry_status")
  @@index([health], map: "idx_template_registry_health")
  @@map("template_registry_entries")
}

model TemplateLifecycleEvent {
  id        String   @id
  action    String
  status    String
  actorId   String?  @map("actor_id")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  @@index([action], map: "idx_template_lifecycle_action")
  @@index([status], map: "idx_template_lifecycle_status")
  @@index([actorId], map: "idx_template_lifecycle_actor")
  @@index([createdAt(sort: Desc)], map: "idx_template_lifecycle_created")
  @@map("template_lifecycle_events")
}

model TemplateActivationSnapshot {
  id                       String    @id
  storeId                  String    @map("store_id")
  previousAssignmentId     String?   @map("previous_assignment_id")
  nextAssignmentId         String    @map("next_assignment_id")
  previousTemplateSlug     String?   @map("previous_template_slug")
  nextTemplateSlug         String    @map("next_template_slug")
  status                   String    @default("READY")
  createdAt                DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  restoredAt               DateTime? @db.Timestamptz(6) @map("restored_at")

  @@index([storeId], map: "idx_template_snapshot_store")
  @@index([status], map: "idx_template_snapshot_status")
  @@index(
    [storeId, status, createdAt(sort: Desc)],
    map: "idx_template_snapshot_store_ready"
  )
  @@index(
    [previousAssignmentId],
    map: "idx_template_snapshot_previous_assignment"
  )
  @@index(
    [nextAssignmentId],
    map: "idx_template_snapshot_next_assignment"
  )
  @@map("template_activation_snapshots")
}
